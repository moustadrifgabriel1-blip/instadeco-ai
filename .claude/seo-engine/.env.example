# seo-engine — exemple de configuration locale.
# Copier ce fichier vers `.env` (gitignoré) et renseigner les VRAIES valeurs.
# NE JAMAIS committer de valeur réelle. En CI, ces variables viennent des
# secrets GitHub (voir README.md).

# --- Google (GSC + GA4) ---
# Chemin vers le fichier JSON du compte de service Google.
# En CI, le workflow écrit le secret GOOGLE_APPLICATION_CREDENTIALS_JSON
# dans un fichier et pointe cette variable dessus.
GOOGLE_APPLICATION_CREDENTIALS=/chemin/vers/service-account.json

# URL exacte de la propriété Search Console (telle qu'enregistrée dans GSC).
GSC_SITE_URL=https://instadeco.app

# ID numérique de la propriété GA4 (ex: 123456789).
GA4_PROPERTY_ID=

# --- PageSpeed Insights ---
PAGESPEED_API_KEY=

# --- LLMs (poste payant — capé) ---
OPENAI_API_KEY=
PERPLEXITY_API_KEY=

# --- Garde-fou budget citations ---
# Cap mensuel STRICT en CHF pour citation_batch.py. Ne pas augmenter
# sans décision explicite : c'est le seul poste à coût variable.
CITATION_BUDGET_CHF=1.50

# Taux de conversion USD -> CHF (les LLMs facturent en USD).
# Mettre une valeur réaliste (ex: 0.88). Pas de fallback inventé côté script.
USD_CHF_RATE=
