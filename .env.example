# ============================================
# InstaDeco - Variables d'Environnement
# ============================================
# Copier ce fichier vers .env.local et remplir les valeurs

# ============================================
# NEXT.JS
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Facebook Pixel (pour les campagnes pub Facebook/Instagram)
NEXT_PUBLIC_FB_PIXEL_ID=

# ============================================
# SUPABASE
# ============================================
# Récupérer depuis: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service Role Key (Server-side uniquement - NE PAS exposer côté client)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ============================================
# FAL.AI (Génération d'images IA)
# ============================================
# Récupérer depuis: https://fal.ai/dashboard/keys
FAL_KEY=your_fal_key_here

# Ancienne config Replicate (gardée au cas où)
# REPLICATE_API_TOKEN=your_replicate_api_token_here

# ============================================
# STRIPE (Paiements)
# ============================================
# Récupérer depuis: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Webhook Secret (créé lors de la configuration du webhook)
# https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Prix IDs pour les packs de crédits (à créer dans Stripe Dashboard)
# https://dashboard.stripe.com/products
STRIPE_PRICE_STARTER=price_starter_id_here
STRIPE_PRICE_PRO=price_pro_id_here
STRIPE_PRICE_UNLIMITED=price_unlimited_id_here


# Prix IDs pour les abonnements (mode: recurring, dans Stripe Dashboard)
# Essentiel: 30 crédits/mois - 19€/mois ou 180€/an
STRIPE_PRICE_SUB_ESSENTIEL_MONTHLY=price_sub_essentiel_monthly_here
STRIPE_PRICE_SUB_ESSENTIEL_ANNUAL=price_sub_essentiel_annual_here
# Pro: 80 crédits/mois - 39€/mois ou 372€/an
STRIPE_PRICE_SUB_PRO_MONTHLY=price_sub_pro_monthly_here
STRIPE_PRICE_SUB_PRO_ANNUAL=price_sub_pro_annual_here
# Business: 200 crédits/mois - 79€/mois ou 756€/an
STRIPE_PRICE_SUB_BUSINESS_MONTHLY=price_sub_business_monthly_here
STRIPE_PRICE_SUB_BUSINESS_ANNUAL=price_sub_business_annual_here

# ============================================
# SÉCURITÉ
# ============================================
RATE_LIMIT_MAX_REQUESTS=10

# ============================================
# SEO - Vérifications & Indexation
# ============================================
# Google Search Console : récupérer le code de vérification HTML tag dans
# https://search.google.com/search-console (propriété > Paramètres > Vérification)
GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools (meta tag)
# https://www.bing.com/webmasters
BING_SITE_VERIFICATION=

# Clé IndexNow : générer une chaîne hexadécimale de 32 caractères (UUID v4 sans tirets)
# Ex: openssl rand -hex 16
# Le fichier <clé>.txt doit contenir la clé en clair et être servi à /<clé>.txt
INDEXNOW_KEY=

# ============================================
# SEO - Crons & Health Check
# ============================================
# Secret partagé pour sécuriser les endpoints /api/cron/*
# Ex: openssl rand -hex 32
CRON_SECRET=

# URL publique du site (utilisée par les crons pour construire les URLs absolues)
# Doit correspondre à NEXT_PUBLIC_APP_URL en production
NEXT_PUBLIC_SITE_URL=https://instadeco.app

# Clé API Google PageSpeed Insights (pour le health check bi-mensuel Core Web Vitals)
# https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# Email du destinataire du rapport SEO health check (envoyé tous les 14 jours)
SEO_REPORT_EMAIL=

# ============================================
# SEO - Génération de contenu (Gemini)
# ============================================
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ============================================
# SEO - Alertes (optionnel)
# ============================================
# Webhook Slack ou Discord pour alertes crons en échec
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# ============================================
# EMAIL (pour rapports SEO, nurturing)
# ============================================
# Provider Resend recommandé : https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=InstaDeco <noreply@instadeco.app>
