{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "app/api/v2/generate/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/generate-articles/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/blog-monitor/route.ts": {
      "maxDuration": 30
    },
    "app/api/cron/seo-health-check/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/storage-cleanup/route.ts": {
      "maxDuration": 60
    },
    "app/[locale]/(marketing)/blog/[slug]/page.tsx": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    },
    {
      "source": "/blog/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    }
  ]
}
