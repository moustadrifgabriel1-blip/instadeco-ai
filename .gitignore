# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# Firebase
firebase-service-account.json
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Médias & outils vidéo locaux (avant/après) — ne pas versionner (arch-07)
/*.mp4
/*.mp3
/*.command
/avant_apres_video.py

# Moteur SEO : rapports et snapshots bruts (trafic, positions, mots-cles).
# Repo PUBLIC -> jamais publies. Restent en local/VPS pour seo-chief.
.claude/seo-engine/reports/*
!.claude/seo-engine/reports/.gitkeep
.claude/seo-engine/data/*
!.claude/seo-engine/data/.gitkeep

# Config locale du serveur de preview (valeurs d'env factices pour la QA visuelle).
.claude/launch.json
